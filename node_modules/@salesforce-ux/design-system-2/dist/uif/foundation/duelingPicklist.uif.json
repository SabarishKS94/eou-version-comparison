{
  "_copyright": "Copyright (c) 2026, Salesforce, Inc., All rights reserved. For full license text, see the LICENSE.txt file",
  "$schema": "https://slds.lightningdesignsystem.com/schemas/uif-foundation.v1.json",
  "apiVersion": "1.0.0",
  "name": "DuelingPicklist",
  "description": "A dueling picklist allows users to move options between two lists.",
  "dateAdded": "2017-03-01",
  "genReady": false,
  "structure": {
    "name": "root",
    "restrict": [
      "div"
    ],
    "description": "Dueling picklist container",
    "attributes": {
      "static": {
        "role": "group"
      },
      "bound": {
        "aria-label": {
          "prop": "label",
          "required": true
        }
      }
    },
    "children": [
      {
        "name": "sourceList",
        "restrict": [
          "div"
        ],
        "description": "Source list container",
        "children": [
          {
            "name": "sourceLabel",
            "restrict": [
              "span"
            ],
            "description": "Source list label",
            "slot": {
              "name": "sourceLabel"
            }
          },
          {
            "name": "sourceListbox",
            "restrict": [
              "ul"
            ],
            "description": "Source options",
            "attributes": {
              "static": {
                "role": "listbox"
              }
            },
            "slot": {
              "name": "sourceOptions",
              "required": true
            }
          }
        ]
      },
      {
        "name": "buttons",
        "restrict": [
          "div"
        ],
        "description": "Move buttons",
        "slot": {
          "name": "buttons"
        }
      },
      {
        "name": "selectedList",
        "restrict": [
          "div"
        ],
        "description": "Selected list container",
        "children": [
          {
            "name": "selectedLabel",
            "restrict": [
              "span"
            ],
            "description": "Selected list label",
            "slot": {
              "name": "selectedLabel"
            }
          },
          {
            "name": "selectedListbox",
            "restrict": [
              "ul"
            ],
            "description": "Selected options",
            "attributes": {
              "static": {
                "role": "listbox"
              }
            },
            "slot": {
              "name": "selectedOptions",
              "required": true
            }
          }
        ]
      }
    ]
  },
  "states": [
    {
      "name": "disabled",
      "type": "boolean",
      "aria": "aria-disabled",
      "description": "Whether the dueling picklist is disabled"
    },
    {
      "name": "grabbed",
      "type": "boolean",
      "description": "whether an item is being dragged"
    },
    {
      "name": "itemSelected",
      "type": "boolean",
      "aria": "aria-selected",
      "description": "whether a list item is selected"
    }
  ],
  "accessibility": {
    "requirements": [
      {
        "id": "listbox-role",
        "description": "Both lists must have role='listbox'"
      },
      {
        "id": "multi-select",
        "description": "Lists should support multi-select with Shift+click"
      }
    ]
  }
}
