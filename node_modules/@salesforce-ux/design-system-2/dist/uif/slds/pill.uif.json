{
  "_copyright": "Copyright (c) 2026, Salesforce, Inc., All rights reserved. For full license text, see the LICENSE.txt file",
  "$schema": "https://slds.lightningdesignsystem.com/schemas/uif-foundation.v1.json",
  "apiVersion": "1.0.0",
  "name": "Pill",
  "description": "A pill displays a label that can optionally be removed.",
  "dateAdded": "2016-03-01",
  "genReady": false,
  "structure": {
    "name": "root",
    "restrict": [
      "span"
    ],
    "description": "Pill container",
    "children": [
      {
        "name": "icon",
        "restrict": [
          "span"
        ],
        "description": "Icon container",
        "renderWhen": "slotFilled",
        "slot": {
          "name": "icon",
          "restrict": [
            "Icon",
            "Avatar"
          ]
        },
        "attributes": {
          "static": {
            "class": "slds-pill__icon_container"
          }
        }
      },
      {
        "name": "label",
        "restrict": [
          "span",
          "a"
        ],
        "description": "Pill label",
        "slot": {
          "name": "default",
          "required": true
        },
        "attributes": {
          "static": {
            "class": "slds-pill__label"
          }
        }
      },
      {
        "name": "remove",
        "restrict": [
          "button",
          "span"
        ],
        "description": "Remove button",
        "renderWhen": "slotFilled",
        "slot": {
          "name": "remove",
          "restrict": [
            "Button"
          ]
        },
        "attributes": {
          "static": {
            "class": "slds-pill__remove"
          }
        }
      },
      {
        "name": "action",
        "restrict": [
          "a"
        ],
        "description": "linked pill action wrapper",
        "attributes": {
          "static": {
            "class": "slds-pill__action"
          }
        }
      },
      {
        "name": "container",
        "restrict": [
          "div"
        ],
        "description": "container for multiple pills",
        "attributes": {
          "static": {
            "class": "slds-pill_container"
          }
        }
      }
    ],
    "attributes": {
      "static": {
        "class": "slds-pill"
      }
    },
    "modifiers": [
      {
        "name": "linked",
        "attribute": "class",
        "value": "slds-pill_link",
        "description": "Pill with clickable label link"
      },
      {
        "name": "bare",
        "attribute": "class",
        "value": "slds-pill_bare",
        "description": "Pill without background or border"
      }
    ]
  },
  "states": [
    {
      "name": "hasError",
      "type": "boolean",
      "aria": "aria-invalid",
      "description": "Whether the pill is in an error state"
    },
    {
      "name": "disabled",
      "type": "boolean",
      "aria": "aria-disabled",
      "description": "Whether the pill is disabled"
    },
    {
      "name": "selected",
      "type": "boolean",
      "aria": "aria-selected",
      "description": "whether the pill is selected"
    }
  ],
  "accessibility": {
    "requirements": [
      {
        "id": "remove-accessible",
        "description": "Remove button must have accessible label indicating what will be removed"
      }
    ]
  },
  "cssSource": "./pill.css",
  "styleApi": {
    "status": "stable",
    "ready": true
  },
  "stateClasses": [
    {
      "state": "hasError",
      "class": "slds-has-error"
    }
  ]
}
