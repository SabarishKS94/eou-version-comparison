  "$schema": "https://slds.lightningdesignsystem.com/schemas/uif-foundation.v1.json",
  "apiVersion": "1.0.0",
  "name": "CheckboxButton",
  "description": "A checkbox styled as a button for grouped selections.",
  "dateAdded": "2017-03-01",
  "genReady": false,
  "structure": {
    "name": "root",
    "restrict": [
      "span"
    ],
    "description": "Checkbox button container",
    "children": [
      {
        "name": "input",
        "restrict": [
          "input"
        ],
        "description": "Hidden checkbox input element",
        "attributes": {
          "static": {
            "type": "checkbox"
          },
          "bound": {
            "id": {
              "prop": "inputId",
              "required": true
            },
            "name": {
              "prop": "name"
            },
            "value": {
              "prop": "value"
            },
            "checked": {
              "prop": "checked"
            },
            "disabled": {
              "prop": "disabled"
            }
          }
        }
      },
      {
        "name": "label",
        "restrict": [
          "label"
        ],
        "attributes": {
          "bound": {
            "for": {
              "prop": "inputId"
            }
          },
          "static": {
            "class": "slds-checkbox_button__label"
          }
        },
        "slot": {
          "name": "default",
          "required": true
        }
      }
    ],
    "attributes": {
      "static": {
        "class": "slds-checkbox_button"
      }
    }
  },
  "states": [
    {
      "name": "checked",
      "type": "boolean",
      "description": "Whether the checkbox is checked"
    },
    {
      "name": "disabled",
      "type": "boolean",
      "aria": "aria-disabled",
      "description": "Whether the checkbox button is disabled"
    },
    {
      "name": "required",
      "type": "boolean",
      "aria": "aria-required",
      "description": "Whether selection is required"
    }
  ],
  "composition": {
    "requiredComponentParent": "CheckboxButtonGroup"
  },
  "accessibility": {
    "requirements": [
      {
        "id": "label-association",
        "description": "Label must be associated with input"
      }
    ]
  },
  "cssSource": "./checkboxButton.css",
  "styleApi": {
    "status": "stable",
    "ready": true
  }
}
