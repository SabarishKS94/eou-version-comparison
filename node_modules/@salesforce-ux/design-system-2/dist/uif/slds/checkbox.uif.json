{
  "_copyright": "Copyright (c) 2026, Salesforce, Inc., All rights reserved. For full license text, see the LICENSE.txt file",
  "$schema": "https://slds.lightningdesignsystem.com/schemas/uif-foundation.v1.json",
  "apiVersion": "1.0.0",
  "name": "Checkbox",
  "description": "A checkable input that communicates if an option is true, false or indeterminate.",
  "dateAdded": "2015-09-04",
  "genReady": false,
  "structure": {
    "name": "root",
    "restrict": [
      "div",
      "span"
    ],
    "description": "Checkbox container",
    "children": [
      {
        "name": "input",
        "restrict": [
          "input"
        ],
        "description": "Native checkbox input",
        "attributes": {
          "static": {
            "type": "checkbox"
          },
          "bound": {
            "id": {
              "prop": "inputId",
              "required": true
            },
            "name": {
              "prop": "name"
            },
            "value": {
              "prop": "value"
            },
            "checked": {
              "prop": "checked"
            },
            "disabled": {
              "prop": "disabled"
            },
            "required": {
              "prop": "required"
            },
            "aria-describedby": {
              "prop": "ariaDescribedBy"
            }
          }
        }
      },
      {
        "name": "label",
        "restrict": [
          "label"
        ],
        "description": "Checkbox label",
        "attributes": {
          "bound": {
            "for": {
              "prop": "inputId"
            }
          }
        },
        "children": [
          {
            "name": "faux",
            "restrict": [
              "span"
            ],
            "description": "Visual checkbox representation"
          },
          {
            "name": "labelText",
            "restrict": [
              "span"
            ],
            "description": "Label text",
            "slot": {
              "name": "default",
              "required": true
            }
          }
        ]
      },
      {
        "name": "requiredIndicator",
        "restrict": [
          "abbr"
        ],
        "description": "required field indicator",
        "attributes": {
          "static": {
            "class": "slds-required"
          }
        }
      },
      {
        "name": "helpIcon",
        "restrict": [
          "div"
        ],
        "description": "help icon with tooltip",
        "renderWhen": "slotFilled",
        "slot": {
          "name": "helpText"
        },
        "attributes": {
          "static": {
            "class": "slds-form-element__icon"
          }
        }
      },
      {
        "name": "errorMessage",
        "restrict": [
          "div"
        ],
        "description": "validation error message",
        "renderWhen": "hasError",
        "attributes": {
          "static": {
            "class": "slds-form-element__help"
          }
        }
      }
    ],
    "attributes": {
      "static": {
        "class": "slds-checkbox"
      }
    },
    "modifiers": [
      {
        "name": "standalone",
        "attribute": "class",
        "value": "slds-checkbox_standalone",
        "description": "Checkbox with separate top-level label"
      }
    ]
  },
  "states": [
    {
      "name": "checked",
      "type": "boolean",
      "description": "Whether the checkbox is checked"
    },
    {
      "name": "indeterminate",
      "type": "boolean",
      "aria": "aria-checked",
      "description": "Whether the checkbox is in an indeterminate state"
    },
    {
      "name": "disabled",
      "type": "boolean",
      "description": "Whether the checkbox is disabled"
    },
    {
      "name": "required",
      "type": "boolean",
      "aria": "aria-required",
      "description": "Whether the checkbox is required"
    },
    {
      "name": "hasError",
      "type": "boolean",
      "description": "whether the checkbox has a validation error"
    }
  ],
  "accessibility": {
    "requirements": [
      {
        "id": "label-association",
        "description": "Checkbox must have an associated label via for/id"
      },
      {
        "id": "error-announcement",
        "description": "Error messages must be associated via aria-describedby"
      }
    ]
  },
  "cssSource": "./checkbox.css",
  "styleApi": {
    "status": "stable",
    "ready": true
  },
  "stateClasses": [
    {
      "state": "hasError",
      "class": "slds-has-error"
    }
  ]
}
