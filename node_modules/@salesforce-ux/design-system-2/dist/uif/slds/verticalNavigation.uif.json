  "$schema": "https://slds.lightningdesignsystem.com/schemas/uif-foundation.v1.json",
  "apiVersion": "1.0.0",
  "name": "VerticalNavigation",
  "description": "Vertical navigation provides hierarchical navigation links within a sidebar.",
  "dateAdded": "2017-03-01",
  "genReady": false,
  "structure": {
    "name": "root",
    "restrict": [
      "nav"
    ],
    "description": "Navigation container",
    "attributes": {
      "bound": {
        "aria-label": {
          "prop": "label",
          "required": true
        }
      },
      "static": {
        "class": "slds-nav-vertical"
      }
    },
    "children": [
      {
        "name": "sections",
        "restrict": [
          "div"
        ],
        "description": "Navigation sections",
        "slot": {
          "name": "default"
        },
        "attributes": {
          "static": {
            "class": "slds-nav-vertical__section"
          }
        }
      },
      {
        "name": "sectionTitle",
        "restrict": [
          "h2"
        ],
        "description": "navigation section heading",
        "attributes": {
          "static": {
            "class": "slds-nav-vertical__title"
          }
        }
      },
      {
        "name": "item",
        "restrict": [
          "li"
        ],
        "description": "navigation list item",
        "repeats": true,
        "attributes": {
          "static": {
            "class": "slds-nav-vertical__item"
          }
        }
      },
      {
        "name": "action",
        "restrict": [
          "a"
        ],
        "description": "navigation action link",
        "attributes": {
          "static": {
            "class": "slds-nav-vertical__action"
          }
        }
      },
      {
        "name": "overflow",
        "restrict": [
          "div"
        ],
        "description": "overflow section with toggle",
        "attributes": {
          "bound": {
            "aria-expanded": {
              "prop": "overflowExpanded"
            }
          },
          "static": {
            "class": "slds-nav-vertical__overflow"
          }
        }
      }
    ],
    "modifiers": [
      {
        "name": "compact",
        "attribute": "class",
        "value": "slds-nav-vertical_compact",
        "description": "Compact spacing"
      },
      {
        "name": "shade",
        "attribute": "class",
        "value": "slds-nav-vertical_shade",
        "description": "Shaded background"
      }
    ]
  },
  "states": [
    {
      "name": "selectedItem",
      "type": "string",
      "aria": "aria-current",
      "description": "ID of selected navigation item"
    },
    {
      "name": "overflowExpanded",
      "type": "boolean",
      "aria": "aria-expanded",
      "description": "whether the overflow section is expanded"
    }
  ],
  "accessibility": {
    "requirements": [
      {
        "id": "nav-label",
        "description": "Navigation must have aria-label"
      },
      {
        "id": "current-page",
        "description": "Active item should have aria-current='page'"
      }
    ]
  },
  "cssSource": "./verticalNavigation.css",
  "styleApi": {
    "status": "stable",
    "ready": true
  },
  "stateClasses": [
    {
      "state": "selectedItem",
      "class": "slds-is-active"
    }
  ]
}
