{
  "_copyright": "Copyright (c) 2026, Salesforce, Inc., All rights reserved. For full license text, see the LICENSE.txt file",
  "$schema": "https://slds.lightningdesignsystem.com/schemas/uif-foundation.v1.json",
  "apiVersion": "1.0.0",
  "name": "RichTextEditor",
  "description": "A rich text editor for formatting text content.",
  "dateAdded": "2017-03-01",
  "genReady": false,
  "structure": {
    "name": "root",
    "restrict": [
      "div"
    ],
    "description": "Rich text editor container",
    "children": [
      {
        "name": "label",
        "restrict": [
          "label",
          "span"
        ],
        "description": "Editor label",
        "renderWhen": "slotFilled",
        "slot": {
          "name": "label"
        },
        "attributes": {
          "static": {
            "class": "slds-form-element__label"
          }
        }
      },
      {
        "name": "toolbar",
        "restrict": [
          "div"
        ],
        "description": "Formatting toolbar",
        "attributes": {
          "static": {
            "role": "toolbar",
            "class": "slds-rich-text-editor__toolbar"
          },
          "bound": {
            "aria-label": {
              "prop": "toolbarLabel"
            }
          }
        },
        "slot": {
          "name": "toolbar"
        }
      },
      {
        "name": "output",
        "restrict": [
          "div"
        ],
        "description": "rich text output display container",
        "attributes": {
          "static": {
            "class": "slds-rich-text-editor__output"
          }
        }
      },
      {
        "name": "editorContainer",
        "restrict": [
          "div"
        ],
        "description": "Editor content container",
        "children": [
          {
            "name": "editor",
            "restrict": [
              "div"
            ],
            "description": "Editable content area",
            "attributes": {
              "static": {
                "role": "textbox",
                "contenteditable": "true",
                "class": "slds-rich-text-area__content slds-grow"
              },
              "bound": {
                "aria-multiline": {
                  "prop": "multiline"
                },
                "aria-labelledby": {
                  "prop": "labelId"
                },
                "aria-describedby": {
                  "prop": "ariaDescribedBy"
                }
              }
            },
            "slot": {
              "name": "default"
            }
          }
        ],
        "attributes": {
          "static": {
            "class": "slds-rich-text-editor__textarea"
          }
        }
      }
    ],
    "attributes": {
      "static": {
        "class": "slds-rich-text-editor slds-form-element"
      }
    },
    "modifiers": [
      {
        "name": "bottomToolbar",
        "attribute": "class",
        "value": "slds-rich-text-editor_bottom-toolbar",
        "description": "Place toolbar at bottom of editor"
      }
    ]
  },
  "states": [
    {
      "name": "disabled",
      "type": "boolean",
      "aria": "aria-disabled",
      "description": "Whether the editor is disabled"
    },
    {
      "name": "readonly",
      "type": "boolean",
      "aria": "aria-readonly",
      "description": "Whether the editor is read-only"
    },
    {
      "name": "hasError",
      "type": "boolean",
      "description": "Whether the editor has a validation error"
    },
    {
      "name": "focused",
      "type": "boolean",
      "description": "whether the editor has keyboard focus"
    }
  ],
  "accessibility": {
    "requirements": [
      {
        "id": "textbox-role",
        "description": "Editor area must have role='textbox' with aria-multiline='true'"
      },
      {
        "id": "toolbar-label",
        "description": "Toolbar must have an accessible label"
      },
      {
        "id": "keyboard-formatting",
        "description": "Common formatting shortcuts (Ctrl+B, Ctrl+I) should work"
      }
    ]
  },
  "cssSource": "./richTextEditor.css",
  "styleApi": {
    "status": "stable",
    "ready": true
  },
  "stateClasses": [
    {
      "state": "disabled",
      "class": "slds-is-disabled"
    },
    {
      "state": "focused",
      "class": "slds-has-focus"
    },
    {
      "state": "hasError",
      "class": "slds-has-error"
    }
  ]
}
